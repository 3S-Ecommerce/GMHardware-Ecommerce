FROM php:8.3-apache

# Instala extensões necessárias para o PostgreSQL e Laravel
RUN apt-get update && apt-get install -y \
    libpq-dev \
    && docker-php-ext-install pdo pdo_pgsql

# Ativa o mod_rewrite do Apache (essencial para rotas do Laravel)
RUN a2enmod rewrite

# Define o diretório de trabalho e copia o código
COPY . /var/www/html
WORKDIR /var/www/html

# Ajusta as permissões de escrita para o Laravel
RUN chown -R www-data:www-data /var/www/html/storage /var/www/html/bootstrap/cache

# Aponta o Apache para a pasta public/ (onde fica o index.php)
ENV APACHE_DOCUMENT_ROOT /var/www/html/public
RUN sed -ri -e 's!/var/www/html!${APACHE_DOCUMENT_ROOT}!g' /etc/apache2/sites-available/*.conf